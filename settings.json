  "model": "glm-5.1",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/Zhuanz/.nvm/versions/node/v22.22.0/bin/cc-connect daemon status >/dev/null 2>&1 || /Users/Zhuanz/.nvm/versions/node/v22.22.0/bin/cc-connect daemon start >/dev/null 2>&1"
          }
